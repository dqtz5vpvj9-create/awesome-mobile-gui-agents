{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/dqtz5vpvj9-create/awesome-mobile-gui-agents/schema/agents.schema.json",
  "title": "Awesome Mobile GUI Agents catalog",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "catalog", "agents"],
  "properties": {
    "schema_version": {
      "const": "1.0"
    },
    "catalog": {
      "type": "object",
      "additionalProperties": false,
      "required": ["title", "tagline", "scope"],
      "properties": {
        "title": {"type": "string", "minLength": 1},
        "tagline": {"type": "string", "minLength": 1},
        "scope": {"type": "string", "minLength": 1}
      }
    },
    "agents": {
      "type": "array",
      "minItems": 20,
      "items": {"$ref": "#/$defs/agent"}
    }
  },
  "$defs": {
    "localized": {
      "type": "object",
      "additionalProperties": false,
      "required": ["en", "zh"],
      "properties": {
        "en": {"type": "string", "minLength": 1},
        "zh": {"type": "string", "minLength": 1}
      }
    },
    "agent": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "name",
        "family",
        "release",
        "code",
        "paper",
        "platforms",
        "perception",
        "actions",
        "capabilities",
        "recovery",
        "evidence",
        "license",
        "runnable",
        "audit",
        "summary",
        "why_included",
        "limitations"
      ],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
        },
        "name": {"type": "string", "minLength": 1},
        "family": {"type": "string", "minLength": 1},
        "release": {
          "type": "object",
          "additionalProperties": false,
          "required": ["date", "basis"],
          "properties": {
            "date": {"type": "string", "format": "date"},
            "basis": {
              "enum": [
                "paper-first-public",
                "code-repository-created",
                "official-release"
              ]
            }
          }
        },
        "code": {
          "type": "object",
          "additionalProperties": false,
          "required": ["repo", "url", "stars_scope"],
          "properties": {
            "repo": {
              "type": "string",
              "pattern": "^[A-Za-z0-9_.-]+/[A-Za-z0-9_.-]+$"
            },
            "url": {"type": "string", "format": "uri"},
            "stars_scope": {
              "enum": ["repository-level", "family-level"]
            }
          }
        },
        "paper": {
          "oneOf": [
            {"type": "null"},
            {
              "type": "object",
              "additionalProperties": false,
              "required": ["title", "url", "venue", "openalex_ids"],
              "properties": {
                "title": {"type": "string", "minLength": 1},
                "url": {"type": "string", "format": "uri"},
                "venue": {"type": "string", "minLength": 1},
                "openalex_ids": {
                  "type": "array",
                  "minItems": 1,
                  "uniqueItems": true,
                  "items": {
                    "type": "string",
                    "pattern": "^(?:https://openalex\\.org/)?W[0-9]+$"
                  }
                }
              }
            }
          ]
        },
        "platforms": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {"enum": ["Android", "iOS", "HarmonyOS"]}
        },
        "perception": {
          "type": "array",
          "minItems": 1,
          "items": {"type": "string", "minLength": 1}
        },
        "actions": {
          "type": "array",
          "minItems": 1,
          "items": {"type": "string", "minLength": 1}
        },
        "capabilities": {
          "type": "array",
          "minItems": 1,
          "items": {"type": "string", "minLength": 1}
        },
        "recovery": {
          "type": "object",
          "additionalProperties": false,
          "required": ["level", "evidence"],
          "properties": {
            "level": {
              "enum": [
                "none-documented",
                "retry",
                "reflection",
                "replanning",
                "backtracking",
                "unknown"
              ]
            },
            "evidence": {"type": "string", "minLength": 1}
          }
        },
        "evidence": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["kind", "label", "url"],
            "properties": {
              "kind": {
                "enum": ["benchmark", "demo", "documentation"]
              },
              "label": {"type": "string", "minLength": 1},
              "url": {"type": "string", "format": "uri"}
            }
          }
        },
        "license": {
          "type": "object",
          "additionalProperties": false,
          "required": ["spdx", "status", "url"],
          "properties": {
            "spdx": {"type": "string", "minLength": 1},
            "status": {"const": "open-source"},
            "url": {"type": "string", "format": "uri"}
          }
        },
        "runnable": {
          "type": "object",
          "additionalProperties": false,
          "required": ["entrypoint_path", "entrypoint_url", "install"],
          "properties": {
            "entrypoint_path": {"type": "string"},
            "entrypoint_url": {"type": "string", "format": "uri"},
            "install": {"type": "string", "minLength": 1}
          }
        },
        "audit": {
          "type": "object",
          "additionalProperties": false,
          "required": ["status", "date", "install_smoke_tested", "notes"],
          "properties": {
            "status": {
              "enum": [
                "links-verified",
                "code-inspected",
                "install-smoke-tested"
              ]
            },
            "date": {"type": "string", "format": "date"},
            "install_smoke_tested": {"type": "boolean"},
            "notes": {"type": "string", "minLength": 1}
          }
        },
        "summary": {"$ref": "#/$defs/localized"},
        "why_included": {"$ref": "#/$defs/localized"},
        "limitations": {"$ref": "#/$defs/localized"}
      }
    }
  }
}
